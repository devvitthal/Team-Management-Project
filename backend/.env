# Backend environment variables for local development.
# Loaded automatically by each service via python-dotenv.
# Copy to .env and fill in real values. Do NOT commit .env.

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASS=PgMarvel@241
POSTGRES_NAME=workshop_db

# Auth
JWT_SECRET_KEY=dev-secret-key-change-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
IS_LOCAL=true

# Service ports — used by start scripts to bind each service
AUTH_PORT=8001
EMPLOYEE_PORT=8002
ORGANIZATION_PORT=8003
ACHIEVEMENT_PORT=8004
VALIDATION_PORT=8005
API_GATEWAY_PORT=8000

# Service base URLs — used by the API gateway to forward requests
AUTH_SERVICE_URL=http://localhost:8001
EMPLOYEE_SERVICE_URL=http://localhost:8002
ORGANIZATION_SERVICE_URL=http://localhost:8003
ACHIEVEMENT_SERVICE_URL=http://localhost:8004
VALIDATION_SERVICE_URL=http://localhost:8005
